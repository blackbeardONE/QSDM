# Copy to ngc.env (gitignored) — never commit real keys.
# NGC CLI API key from https://ngc.nvidia.com/
NGC_CLI_API_KEY=Charming123
# After filling the key: .\scripts\verify-ngc-docker.ps1 (from this app folder)

# Optional: push proof bundles into a running QSDM+ node (secret must match node's QSDMPLUS_NGC_INGEST_SECRET)
# QSDMPLUS_NGC_REPORT_URL=http://host.docker.internal:8080/api/v1/monitoring/ngc-proof
# QSDMPLUS_NGC_INGEST_SECRET=Charming123
# Optional: include qsdmplus_node_id in proof JSON when node uses QSDMPLUS_NVIDIA_LOCK_EXPECTED_NODE_ID
# QSDMPLUS_NGC_PROOF_NODE_ID=my-validator-1
# QSDMPLUS_NGC_PROOF_HMAC_SECRET=Charming123
# When node has nvidia_lock_require_ingest_nonce: QSDMPLUS_NGC_FETCH_CHALLENGE=true (GET /ngc-challenge before each bundle; 429 uses Retry-After, retries up to QSDMPLUS_NGC_CHALLENGE_MAX_RETRIES, default 4)
# Optional: QSDMPLUS_NGC_CHALLENGE_JITTER_MAX_SEC=8  # random sleep 0..8s before each challenge (NAT / many validators)
