# AWS credentials for external notifications
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# VIP secret key
VIP_SECRET_KEY="your-vip-secret-key"

# QSDM Hive talks to the public home gateway by default outside tests.
# The gateway safely proxies consumer-read and signed-submit API calls to Core.
QSDM_GATEWAY_API_URL="https://api.qsdm.tech/attest/home-validator/api/v1"
QSDM_HIVE_API_URL="https://api.qsdm.tech/attest/home-validator/api/v1"
# Leave empty for the platform default: gateway on Linux, local Core on Windows.
# Linux validator operators can set http://127.0.0.1:8080/api/v1 explicitly.
QSDM_CORE_API_URL=""
QSDM_DASHBOARD_URL="http://localhost:8081"
QSDM_TASK_RUNTIME_MODE="qsdm-native"
QSDM_WALLET_ADDRESS=""
QSDM_TASK_ACTION_SENDER=""
QSDM_TASK_ACTION_SIGNER="cli"
QSDM_TASK_ACTION_CLI_PATH="qsdmcli"
QSDM_TASK_ACTION_KEYSTORE_PATH=""
QSDM_TASK_ACTION_PASSPHRASE_FILE=""
QSDM_ENABLE_LOCAL_SIGNED_LOOP="0"
QSDM_NATIVE_SUBMISSION_METHODS="checkSubmissionAndUpdateRound"

# Release/version policy. Production builds use these defaults and require an
# exact match with the published latest.yml version before wallet/task access.
QSDM_HIVE_VERSION_MANIFEST_URL="https://qsdm.tech/downloads/latest.yml"
QSDM_HIVE_UPDATE_FEED_URL="https://qsdm.tech/downloads"
QSDM_HIVE_DOWNLOAD_URL="https://qsdm.tech/download.html"
